# 网站规范 URL（用于 sitemap / robots / OpenGraph / metadataBase）
NEXT_PUBLIC_SITE_URL=https://tribox.md

# tribox-sync-server 的 API 基础 URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# tribox 桌面客户端的 custom scheme（邀请落地页唤起 app）
NEXT_PUBLIC_APP_SCHEME=tribox

# 桌面客户端发布版本号（Tauri 产物文件名内嵌的版本）
# 留空时 /download 页会显示 "即将推出"，所有下载按钮被禁用
NEXT_PUBLIC_RELEASE_VERSION=

# 桌面客户端发布物的基础 URL（不含文件名）
# 例：https://github.com/tribox-md/tribox-desktop/releases/download/v1.0.0
# 与 Tauri 产物文件名拼接出最终下载链接
NEXT_PUBLIC_RELEASE_BASE_URL=

# Stripe Publishable Key（前端调用 Stripe.js 时使用，可公开）
# 服务端 secret key 配置在 tribox-sync-server 的 STRIPE_SECRET_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
